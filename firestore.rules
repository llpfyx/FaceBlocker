rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global leaderboard: anyone can read, anyone can submit a new score
    // (no auth in this MVP), but scores can never be edited or deleted,
    // and each entry must roughly match the shape the game writes.
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if
        request.resource.data.keys().hasOnly(['username', 'score', 'phase', 'kills', 'ts']) &&
        request.resource.data.username is string &&
        request.resource.data.username.size() <= 12 &&
        request.resource.data.score is int &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 100000000 &&
        request.resource.data.phase is int &&
        request.resource.data.kills is int;
      allow update, delete: if false;
    }
  }
}
